# ─── Required ─────────────────────────────────────────────────────────────────
PHONE_NUMBER=628123456789

# ─── Session storage ──────────────────────────────────────────────────────────
# SESSION_TYPE=multifile   (default) — multi-file JSON auth state
# SESSION_TYPE=sqlite      — SQLite-backed auth (atomic writes, more reliable)
SESSION_TYPE=multifile

# ─── AI features ──────────────────────────────────────────────────────────────
# Text, vision, and chat — free API key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Image generation — free token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ─── Optional / legacy (no longer used by default) ────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# ─── Server ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
PORT=3000

# ─── GitHub integration (for .push command and /push endpoint) ────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# ─── Security ─────────────────────────────────────────────────────────────────
# Optional secret for the /push HTTP endpoint
# PUSH_SECRET=your_secret_here
